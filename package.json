{
  "name": "ts-dep",
  "version": "1.0.0",
  "description": "CLI-библиотека для статического анализа зависимостей в TypeScript-проектах",
  "module": "src/cli/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --target node --outfile dist/cli.js"
  },
  "bin": {
    "ts-dep": "./dist/cli.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cytoscape": "^3.31.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "commander": "^14.0.3",
    "cytoscape": "^3.33.3",
    "open": "^11.0.0"
  }
}
